{
  "name": "use-stellar",
  "version": "0.1.4",
  "description": "React hooks for the Stellar network - the wagmi of Stellar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/israelolrunfemi/use-stellar.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/israelolrunfemi/use-stellar#readme",
  "bugs": {
    "url": "https://github.com/israelolrunfemi/use-stellar/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest --testPathPattern=integration",
    "typecheck": "tsc --noEmit",
    "test:package": "node scripts/smoke-test.js",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@stellar/freighter-api": "6.0.1",
    "@stellar/stellar-sdk": "^12.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-hooks": "^8.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "stellar",
    "soroban",
    "react",
    "hooks",
    "blockchain",
    "web3",
    "crypto",
    "xlm",
    "usdc"
  ],
  "license": "MIT"
}